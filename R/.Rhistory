library(tidyverse)
library(car) # this contained the `leveneTest()` function to implement a Levene's test for homogeneity of variance across groups
library(HDSinRdata)
library(gt)
library(gtsummary)
data(tex_itop)
# our outcome of interest here is number of induced terminations of pregnancy (referred to as ITOPs or abortions below) in 2021 per 1000 females ages 15-49 in each county
# we use the number of females as a proxy to scale the number of abortions to the population size, though this is not truly reflective of the number of people who can give birth in each county
count_rates_2021 <- tex_itop$total_rate[tex_itop$year == 2021]
hist(county_rates_2021, breaks=35)
# our outcome of interest here is number of induced terminations of pregnancy (referred to as ITOPs or abortions below) in 2021 per 1000 females ages 15-49 in each county
# we use the number of females as a proxy to scale the number of abortions to the population size, though this is not truly reflective of the number of people who can give birth in each county
county_rates_2021 <- tex_itop$total_rate[tex_itop$year == 2021]
hist(county_rates_2021, breaks=35)
library(tidyverse)
library(car) # this contained the `leveneTest()` function to implement a Levene's test for homogeneity of variance across groups
library(HDSinRdata)
library(gt)
library(gtsummary)
data(tex_itop)
# our outcome of interest here is number of induced terminations of pregnancy (referred to as ITOPs or abortions below) in 2021 per 1000 females ages 15-49 in each county
# we use the number of females as a proxy to scale the number of abortions to the population size, though this is not truly reflective of the number of people who can give birth in each county
county_rates_2021 <- tex_itop$total_rate[tex_itop$year == 2021]
hist(county_rates_2021, breaks=35)
# lets now look at the ten counties with the highest rates
tex_itop %>%
filter(year == 2021) %>%
slice_max(n = 10, total_rate) %>%
dplyr::select(c(county, total_itop, total_rate))
# lets look at the mean abortion rate among counties (the estimate from the CDC nationally is 11.2)
mean(county_rates_2021, na.rm=TRUE)
est_mean <- mean(county_rates_2021, na.rm=TRUE)
est_sd <- sd(county_rates_2021)
z_alpha <- dnorm(1-0.05/2)
n <- length(county_rates_2021)
c(est_mean - z_alpha * est_sd / sqrt(n),
est_mean + z_alpha * est_sd / sqrt(n))
lower <- round(est_mean - z_alpha * est_sd / sqrt(n), 3)
upper <- round(est_mean + Z_alpha * est_sd / sqrt(n), 3)
est_mean <- mean(county_rates_2021, na.rm=TRUE)
est_sd <- sd(county_rates_2021)
z_alpha <- dnorm(1-0.05/2)
n <- length(county_rates_2021)
c(est_mean - z_alpha * est_sd / sqrt(n),
est_mean + z_alpha * est_sd / sqrt(n))
lower <- round(est_mean - z_alpha * est_sd / sqrt(n), 3)
upper <- round(est_mean + z_alpha * est_sd / sqrt(n), 3)
paste("Confidence Interval: (", lower, ",", upper, ")")
lower <- round(est_mean - z_alpha * est_sd / sqrt(n), 3)
upper <- round(est_mean + z_alpha * est_sd / sqrt(n), 3)
paste("Confidence Interval: (",lower, ",",upper, ")")
t.test(county_rates_2021, alternative = "less", mu = 6.23,
conf.level = 0.95)
t_test_res <- t.test(county_rates_2021, alternative="less", mu=6.23, conf.level=0.95)
t_test_res <- t.test(county_rates_2021, alternative="less", mu=6.23, conf.level=0.95)
names(t_test_res)
t_test_res <- t.test(county_rates_2021, alternative="less", mu=6.23, conf.level=0.95)
names(t_test_res)
t_test_res$p.value
county_rates_2019 <- tex_itop$total_itop[tex_itop$year == 2019]
t.test(county_rates_2019, alternative="less", mu=-6.4736, conf.level=0.95)
county_rates_2019 <- tex_itop$total_itop[tex_itop$year == 2019]
t.test(county_rates_2019, alternative="less", mu=6.23, conf.level=0.95)
county_rates_2019 <- tex_itop$total_itop[tex_itop$year == 2019]
mean(county_rates_2019, na.rm=TRUE)
t.test(county_rates_2019, alternative="less", mu=6.23, conf.level=0.95)
county_rates_2019 <- tex_itop$total_itop[tex_itop$year == 2019]
mean(county_rates_2019, na.rm=TRUE)
hist(county_rates_2019, breaks=35)
t.test(county_rates_2019, alternative="less", mu=6.23, conf.level=0.95)
wilcox_res <- wilcox.test(county_rates_2021, alternative="less", mu=5.14, # 5.14 is the median rate from 2020
conf.level = 0.95)
wilcox_res
wilcox_res$p.value
# we take the same 2020 and 2021 rates by county and pivot the data into a wider form to include rate columns and now we are going to also filter out the outliers
# if we first look at a scatter plot of the data, we can see a linear correlation between the two
county_rates <- tex_itop %>%
dplyr::select(c(county, total_rate, year)) %>%
filter(!(county %in% c("Terrell", "Loving")),
year %in% c(2020, 2021)) %>%
pivot_wider(names_from = year, values_from = total_rate) %>%
na.omit() %>%
rename("y2020" = "2020", "y2021" = "2021")
head(county_rates)
ggplot(county_rates) +
geom_point(aes(x=y2020, y=y2021)) +
labs(x = "2020 ITOP Rates", y="2021 ITOP Rates")
# Correlation
cor(county_rates$y2020, county_rates$y2021)
# Covariance
cov(county_rates$y2020, county_rates$y2021)
# here we are testing whether there is a non-zero correlation between the 2020 and 2021 county rates using the Pearson's correlation
cor_test_res <- cor.test(county_rates$y2020,
county_rates$y2021,
method = "pearson")
cor_test_res
cor_test_res$conf.int
t_test_two_res <- t.test(x = county_rates$y2020,
y = county_rates$y2021)
t_test_two_res
t_test_two_res$conf.int
t_test_unpaired <- t.test(rate_change ~ urban,
data = county_rates_type)
# first we create a variable describing the rate change between these years using the following code
# we use the change in rate instead of percent change to avoid infinite or undefined values
county_rates_type <- tex_itop %>%
dplyr::select(c(county, urban, county_type, total_rate, year)) %>%
filter(total_rate < 15, year %in% c(2020, 2021)) %>%
pivot_wider(names_from = year, values_from = total_rate) %>%
na.omit() %>%
rename("y2020" = "2020", "y2021" = "2021") %>%
mutate(rate_change = (y2021 - y2020))
t_test_unpaired <- t.test(rate_change ~ urban,
data = county_rates_type)
t_test_unpaired
t_test_unpaired$estimate
x <- county_rates_type$rate_change[county_rates_type$urban == 'Urban']
y <- county_rates_type$rate_change[county_rates_type$rural == 'Rural']
t.test(x = x, y = y, paired = FALSE)
x <- county_rates_type$rate_change[county_rates_type$urban == 'Urban']
y <- county_rates_type$rate_change[county_rates_type$urban == 'Rural']
t.test(x = x, y = y, paired = FALSE)
# this is going to yeield the same results if we specify the vectors x and y
kruskal.test(county_rates_type$rate_change,
county_rates_type$county_type)
# for the `aov()` function, we specify the test using a formula and the data (we need to use the `summary()` function to see the p-values)
aov_res <- aov(rate_change ~ county_type,
data = county_rates_type)
summary(aov_res)
colnames(tex_itop)
county_rates_2016 <- tex_itop %>%
filter(year == 2016) %>%
pivot_longer(
cols = matches("_(itop|rate)$"),   # select all count and rate columns
names_to = c("race", ".value"),    # create two new columns: race and the "value" columns
names_pattern = "(.*)_(itop|rate)" # extract race and metric type
)
aov_res_2016 <- aov(itop ~ race,
data = county_rates_2016)
summary(aov_res_2016)
# for this data, we will compare the variance in abortion rates in 2021 between urban and rural counties using an F-test
# the null hypothesis for this test is that the variance in both groups is equal
f_test <- var.test(y2021 ~ urban, county_rates_type)
f_test
f_test$estimate
