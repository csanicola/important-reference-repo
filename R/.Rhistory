county_rates <- tex_itop %>%
dplyr::select(c(county, total_rate, year)) %>%
filter(!(county %in% c("Terrell", "Loving")),
year %in% c(2020, 2021)) %>%
pivot_wider(names_from = year, values_from = total_rate) %>%
na.omit() %>%
rename("y2020" = "2020", "y2021" = "2021")
